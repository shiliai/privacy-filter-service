# Privacy Filter Service configuration
# Copy to ~/.config/privacy-filter/config.toml and adjust as needed.
# All fields have sensible defaults except model_path (REQUIRED).

[service]
host = "0.0.0.0"           # Listen address
port = 8765                 # Listen port (1-65535)
device = "cuda"              # "cuda" or "cpu"
output_mode = "typed"    # "typed" or "redacted"
decode_mode = "viterbi"     # "viterbi" or "argmax"
model_path = ""             # REQUIRED — path to OPF checkpoint (or set OPF_CHECKPOINT env)
log_level = "INFO"          # Python logging level

[hook]
base_url = "http://127.0.0.1:8765"  # Service URL the hook calls
request_timeout_s = 5.0             # Hook HTTP timeout in seconds (1-60)
max_file_bytes = 262144             # Max file size the hook will send (≤ 1048576 = 1 MB)
max_inflight_warns_per_5min = 1     # Rate-limit for inflight warnings
