# Privacy Filter Service — environment variable overrides
# Copy to ~/.config/privacy-filter/env and uncomment what you need.
# These override the corresponding values in config.toml.
# The '-' prefix in the systemd unit makes this file optional.

# --- Service config ---
# PRIVACY_FILTER_LISTEN_HOST=0.0.0.0
# PRIVACY_FILTER_LISTEN_PORT=8765
# PRIVACY_FILTER_URL=http://192.168.88.75:8765
# PRIVACY_FILTER_LOG_LEVEL=INFO
# PRIVACY_FILTER_DEVICE=cuda
# PRIVACY_FILTER_DECODE_BACKEND=upstream
# PRIVACY_FILTER_MAX_FILE_BYTES=262144
# PRIVACY_FILTER_TIMEOUT_S=5

# --- Local rules-only fallback service ---
# PRIVACY_FILTER_FALLBACK_HOST=127.0.0.1
# PRIVACY_FILTER_FALLBACK_PORT=8766
# PRIVACY_FILTER_FALLBACK_URL=http://127.0.0.1:8766

# --- Model ---
# OPF_CHECKPOINT=/mnt/LLM/OpenAI/privacy_filter

# --- Config path ---
# PRIVACY_FILTER_CONFIG=/home/$USER/.config/privacy-filter/config.toml
