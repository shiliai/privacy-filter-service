#!/usr/bin/env bash

set -u
umask 077

source "$(dirname "$0")/_lib.sh"

trap 'pf_cleanup_old_patches' EXIT

if pf_skip_active; then
  exit 0
fi

health_response=""
if ! health_response="$(curl -fsS -m 2 "$(pf_url)/health" 2>/dev/null)"; then
  pf_warn_once unavailable "service down, fail-open"
  exit 0
fi

if ! printf '%s' "$health_response" | python3 -c 'import json, sys; data = json.load(sys.stdin); raise SystemExit(0 if data.get("ready") else 1)'; then
  pf_warn_once unavailable "service down, fail-open"
  exit 0
fi

mapfile -t staged_paths < <(git diff --cached --name-only --diff-filter=ACM)

if [ "${#staged_paths[@]}" -eq 0 ]; then
  exit 0
fi

for path in "${staged_paths[@]}"; do
  if [ -n "$(git diff --name-only -- "$path")" ]; then
    printf '%s\n' 'Partial staging not supported in v1. Either fully stage (git add <file>) or unstage (git restore --staged <file>).' >&2
    exit 1
  fi
done

pf_ensure_dir
privacy_dir="$(pf_privacy_dir)"
orig_root="$privacy_dir/orig"
redacted_root="$privacy_dir/redacted"
mkdir -p "$orig_root" "$redacted_root"

declare -a pii_paths=()
declare -A label_counts=()
total_spans=0

for path in "${staged_paths[@]}"; do
  if ! pf_is_text_file "$path"; then
    continue
  fi

  if pf_is_lfs_pointer "$path"; then
    continue
  fi

  orig_file="$orig_root/$path"
  mkdir -p "$(dirname "$orig_file")"
  if ! git show ":$path" > "$orig_file"; then
    pf_warn_once unavailable "failed to read staged content, fail-open"
    exit 0
  fi

  bytes="$(wc -c < "$orig_file" | tr -d '[:space:]')"
  if pf_too_large "$bytes"; then
    printf '[privacy-filter] skipping oversized file: %s (%s bytes)\n' "$path" "$bytes" >&2
    continue
  fi

  http_meta_file="$privacy_dir/http-$$.meta"
  if ! response="$(python3 -c 'import json, sys; print(json.dumps({"text": sys.stdin.read()}))' < "$orig_file" | pf_post_json /redact 2> "$http_meta_file")"; then
    pf_warn_once unavailable "redaction request failed, fail-open"
    exit 0
  fi

  http_code="$(python3 -c 'import sys; data = sys.stdin.read().splitlines(); print(data[-1].split(":", 1)[1] if data else "0")' < "$http_meta_file")"
  rm -f "$http_meta_file"
  if [ "$http_code" != "200" ]; then
    pf_warn_once unavailable "service unavailable, fail-open"
    exit 0
  fi

  if ! span_count="$(printf '%s' "$response" | python3 -c 'import json, sys; data = json.load(sys.stdin); print(int(data.get("summary", {}).get("span_count", 0)))')"; then
    pf_warn_once unavailable "invalid service response, fail-open"
    exit 0
  fi
  if [ "$span_count" = "0" ]; then
    continue
  fi

  redacted_file="$redacted_root/$path"
  mkdir -p "$(dirname "$redacted_file")"
  if ! printf '%s' "$response" | python3 -c 'import json, sys; data = json.load(sys.stdin); sys.stdout.write(data["redacted_text"])' > "$redacted_file"; then
    pf_warn_once unavailable "invalid service response, fail-open"
    exit 0
  fi
  while IFS=$'\t' read -r label count; do
    [ -n "$label" ] || continue
    label_counts["$label"]=$(( ${label_counts["$label"]:-0} + count ))
  done < <(printf '%s' "$response" | python3 -c 'import json, sys; data = json.load(sys.stdin); by_label = data.get("summary", {}).get("by_label", {});
for key, value in by_label.items():
    print(f"{key}\t{value}")')

  total_spans=$((total_spans + span_count))
  pii_paths+=("$path")
done

if [ "${#pii_paths[@]}" -eq 0 ]; then
  exit 0
fi

patch_file="$privacy_dir/redact-$(date +%s)-$$.patch"
for path in "${pii_paths[@]}"; do
  diff -u "$orig_root/$path" "$redacted_root/$path" --label "a/$path" --label "b/$path" >> "$patch_file" || [ $? -eq 1 ]
done

chmod 600 "$patch_file"

if ! git apply --check "$patch_file" >/dev/null 2>&1; then
  rm -f "$patch_file"
  pf_warn_once unavailable "generated patch invalid, fail-open"
  exit 0
fi

printf '[privacy-filter] blocked commit: detected PII in %s staged file(s), %s span(s)\n' "${#pii_paths[@]}" "$total_spans" >&2
if [ "${#label_counts[@]}" -gt 0 ]; then
  printf '[privacy-filter] by label:' >&2
  for label in "${!label_counts[@]}"; do
    printf ' %s=%s' "$label" "${label_counts[$label]}" >&2
  done
  printf '\n' >&2
fi
printf '[privacy-filter] review patch: %s\n' "$patch_file" >&2
printf '[privacy-filter] apply with: git apply --index "%s"\n' "$patch_file" >&2
exit 1
